{
    "manifest_version": 3,
    "name": "Personall Dashboard",
    "version": "1.0.0",
    "description": "Wife's extension",
    "action": {
        "default_icon": "dash.png"
    },
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "content_scripts": [{
  "js": ["./node_modules/@microlink/mql/src/main.mjs", "index.js"],
  "matches": ["<all_urls>"]
}]
}